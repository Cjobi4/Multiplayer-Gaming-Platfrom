<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.ucalgary.seng300.client.screens.welcomeController">
   <children>
      <AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #F9EDE1;" styleClass="pane">
         <children>
            <Button fx:id="welcomeButton" layoutX="305.0" layoutY="149.0" mnemonicParsing="false" onAction="#onWelcomeButtonClick" prefHeight="25.0" prefWidth="115.0" styleClass="basic-button" text="Login" textFill="#866b59">
               <font>
                  <Font name="Dubai Regular" size="12.0" />
               </font></Button>
            <Label alignment="CENTER" contentDisplay="CENTER" layoutX="100.0" layoutY="50.0" prefHeight="31.0" prefWidth="409.0" text="Welcome to (insert project name here lol)!" textAlignment="CENTER" textFill="#866b59">
               <font>
                  <Font name="Dubai Bold" size="21.0" />
               </font></Label>
            <Button fx:id="createAccountButton" layoutX="177.0" layoutY="149.0" mnemonicParsing="false" onAction="#onCreateAccountButtonClick" prefHeight="25.0" prefWidth="115.0" styleClass="basic-button" text="Create Account" textFill="#866b59">
               <font>
                  <Font name="Dubai Regular" size="12.0" />
               </font></Button>
            <ImageView fitHeight="151.0" fitWidth="294.0" layoutX="158.0" layoutY="200.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </AnchorPane>
   </children>
</HBox>
