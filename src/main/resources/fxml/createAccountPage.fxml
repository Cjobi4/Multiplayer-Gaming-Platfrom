<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>


<HBox xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.ucalgary.seng300.client.screens.createAccountController">
   <children>
      <AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f2f2ff;">
         <children>
            <Label layoutX="229.0" layoutY="50.0" text="Create Account">
               <font>
                  <Font size="21.0" />
               </font>
            </Label>
            <TextField layoutX="226.0" layoutY="130.0" prefHeight="25.0" prefWidth="243.0" />
            <Label layoutX="120.0" layoutY="133.0" text="Enter Username: ">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <Label layoutX="120.0" layoutY="171.0" text="Enter Password: ">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TextField layoutX="226.0" layoutY="168.0" prefHeight="25.0" prefWidth="243.0" />
            <Button fx:id="ContinueButton" layoutX="226.0" layoutY="240.0" mnemonicParsing="false" text="Create Account And Continue" />
            <Label layoutX="226.0" layoutY="209.0" prefHeight="17.0" prefWidth="243.0" text="ERROR FIELD" textFill="RED" />
            <Button fx:id="backButton" layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#onBackButtonClick" prefHeight="25.0" prefWidth="65.0" text="Back" />
         </children>
      </AnchorPane>
   </children>
</HBox>
