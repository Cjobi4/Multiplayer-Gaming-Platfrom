<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.ucalgary.seng300.client.screens.createAccountController">
   <children>
      <AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #F9EDE1;" styleClass="pane">
         <children>
            <Label layoutX="230.0" layoutY="50.0" text="Create Account" textFill="#866b59">
               <font>
                  <Font name="Dubai Bold" size="21.0" />
               </font>
            </Label>
            <TextField fx:id="userNameField" layoutX="230.0" layoutY="130.0" prefHeight="25.0" prefWidth="245.0" style="-fx-background-color: #F7C5AD;" />
            <Label layoutX="120.0" layoutY="133.0" text="Enter Username: " textFill="#866b59">
               <font>
                  <Font name="Dubai Bold" size="14.0" />
               </font>
            </Label>
            <Label layoutX="120.0" layoutY="170.0" text="Enter Password: " textFill="#866b59">
               <font>
                  <Font name="Dubai Bold" size="14.0" />
               </font>
            </Label>
            <PasswordField fx:id="passwordField" layoutX="230.0" layoutY="168.0" prefHeight="25.0" prefWidth="245.0" style="-fx-background-color: #F7C5AD;" />
            <Button fx:id="continueButton" layoutX="230.0" layoutY="245.0" mnemonicParsing="false" onAction="#onContinueButtonClick" styleClass="basic-button" text="Create Account And Continue" />
            <Label fx:id="errorField" layoutX="230.0" layoutY="205.0" prefHeight="17.0" prefWidth="243.0" text="" textFill="#ff006e">
               <font>
                  <Font name="Dubai Medium" size="17.0" />
               </font></Label>
            <Button fx:id="backButton" layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#onBackButtonClick" prefHeight="25.0" prefWidth="65.0" styleClass="basic-button" text="Back" />
         </children>
      </AnchorPane>
   </children>
</HBox>
