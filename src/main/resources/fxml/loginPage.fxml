<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.ucalgary.seng300.client.screens.loginController">
   <children>
      <AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #F9EDE1;" styleClass="pane">
         <children>
            <Button fx:id="loginButton" layoutX="230.0" layoutY="245.0" mnemonicParsing="false" onAction="#onLoginButtonClick" prefHeight="30.0" prefWidth="90.0" styleClass="basic-button" text="Login" textFill="#866b59" />
            <Label layoutX="270.0" layoutY="50.0" prefHeight="39.0" prefWidth="54.0" text="Login" textAlignment="CENTER" textFill="#866b59">
               <font>
                  <Font name="Dubai Bold" size="21.0" />
               </font>
            </Label>
            <Button fx:id="createAccountButton" layoutX="330.0" layoutY="245.0" mnemonicParsing="false" onAction="#onCreateAccountButtonClick" prefHeight="30.0" prefWidth="141.0" styleClass="basic-button" text="Create Account" textFill="#866b59">
               <font>
                  <Font name="Dubai Medium" size="12.0" />
               </font></Button>
            <Button fx:id="backButton" layoutX="14.0" layoutY="360.0" mnemonicParsing="false" onAction="#onBackButtonClick" prefHeight="25.0" prefWidth="65.0" styleClass="basic-button" text="Back" />
            <TextField fx:id="userNameField" layoutX="230.0" layoutY="130.0" prefHeight="25.0" prefWidth="245.0" style="-fx-background-color: #F7C5AD;" />
            <TextField fx:id="passwordField" layoutX="230.0" layoutY="168.0" prefHeight="25.0" prefWidth="245.0" style="-fx-background-color: #F7C5AD;" />
            <Label layoutX="120.0" layoutY="133.0" text="Enter Username: " textFill="#866b59">
               <font>
                  <Font name="Dubai Bold" size="14.0" />
               </font>
            </Label>
            <Label layoutX="120.0" layoutY="170.0" text="Enter Password: " textFill="#866b59">
               <font>
                  <Font name="Dubai Bold" size="14.0" />
               </font>
            </Label>
            <Label fx:id="errorField" layoutX="230.0" layoutY="205.0" prefHeight="17.0" prefWidth="243.0" text="ERROR FIELD" textFill="#ff006e">
               <font>
                  <Font name="Dubai Medium" size="17.0" />
               </font>
            </Label>
            <Button fx:id="bypassButton" layoutX="105.0" layoutY="362.0" mnemonicParsing="false" onAction="#onByPassButtonClick" prefHeight="25.0" prefWidth="103.0" text="BYPASS LOGIN" />
         </children>
      </AnchorPane>
   </children>
</HBox>
