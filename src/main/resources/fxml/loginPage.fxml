<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.ucalgary.seng300.client.screens.loginController">
   <children>
      <AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f2f2ff;">
         <children>
            <Button fx:id="loginButton" layoutX="251.0" layoutY="232.0" mnemonicParsing="false" onAction="#onLoginButtonClick" text="Login" />
            <Label layoutX="272.0" layoutY="50.0" prefHeight="39.0" prefWidth="54.0" text="Login" textAlignment="CENTER">
               <font>
                  <Font size="21.0" />
               </font>
            </Label>
            <Label layoutX="185.0" layoutY="151.0" text="Username" />
            <Label layoutX="186.0" layoutY="192.0" text="Password" />
            <TextField layoutX="251.0" layoutY="147.0" />
            <TextField layoutX="251.0" layoutY="188.0" prefHeight="25.0" prefWidth="149.0" />
            <Button fx:id="createAccountButton" layoutX="300.0" layoutY="232.0" mnemonicParsing="false" onAction="#onCreateAccountButtonClick" prefHeight="25.0" prefWidth="101.0" text="Create Account" />
            <Label layoutX="267.0" layoutY="273.0" text="Forgot password?" />
         </children>
      </AnchorPane>
   </children>
</HBox>
