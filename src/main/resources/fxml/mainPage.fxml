<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f2f2ff;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.ucalgary.seng300.client.screens.mainController">
   <center>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="TOP_CENTER" prefWidth="220.0" spacing="10.0" style="-fx-border-color: #808080; -fx-border-radius: 5; -fx-background-color: #ffffffff;">
               <children>
                  <Label text="Leaderboard">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
               </children>
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" top="10.0" />
               </HBox.margin>
            </VBox>

            <VBox alignment="TOP_CENTER" prefWidth="260.0" spacing="20.0">
               <children>
                  <VBox alignment="TOP_CENTER" prefHeight="300.0" style="-fx-border-color: #808080; -fx-border-radius: 5; -fx-background-color: #ffffff;">
                     <children>
                        <Label text="Game List">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  <Button fx:id="gameSelectButton" mnemonicParsing="false" onAction="#onGameSelectButtonClick" prefHeight="55.0" prefWidth="215.0" text="Select Opponent">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>

            <VBox alignment="TOP_CENTER" prefWidth="300.0" style="-fx-border-color: #808080; -fx-border-radius: 5; -fx-background-color: #ffffff;">
               <children>
                  <Label text="Game Details">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                  <StackPane prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#d4dbe1" height="150.0" stroke="BLACK" width="200.0" />
                        <Label text="Thumbnail" />
                     </children>
                  </StackPane>
               </children>
               <HBox.margin>
                  <Insets bottom="10.0" right="10.0" top="10.0" />
               </HBox.margin>
            </VBox>
         </children>
      </HBox>
   </center>
   <top>
      <HBox prefHeight="22.0" prefWidth="800.0" BorderPane.alignment="CENTER">
         <children>
            <MenuBar prefHeight="28.0" prefWidth="625.0">
              <menus>
                <Menu mnemonicParsing="false" text="| Change Log |" />
                <Menu mnemonicParsing="false" text="| Info |">
                  <items>
                    <MenuItem mnemonicParsing="false" text="About" />
                  </items>
                </Menu>
                  <Menu mnemonicParsing="false" text="| Admin Control |">
                    <items>
                      <MenuItem mnemonicParsing="false" text="Action 1" />
                    </items>
                  </Menu>
              </menus>
            </MenuBar>
            <ButtonBar prefHeight="28.0" prefWidth="207.0">
              <buttons>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="🔍" />
                  <TextField prefHeight="26.0" />
                <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="167.0" text="Log Out" />
              </buttons>
            </ButtonBar>
         </children></HBox>
   </top>
</BorderPane>
