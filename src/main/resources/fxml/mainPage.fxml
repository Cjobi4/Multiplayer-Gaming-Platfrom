<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f2f2ff;" styleClass="pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.ucalgary.seng300.client.screens.mainController">
   <center>
      <HBox prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #F9EDE1;" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="TOP_CENTER" prefWidth="220.0" spacing="10.0" style="-fx-border-color: #DEB499; -fx-border-radius: 7; -fx-background-color: #FCE0D2;">
               <children>
                  <Label text="Leaderboard" textFill="#866b59">
                     <font>
                        <Font name="Dubai Regular" size="18.0" />
                     </font>
                  </Label>
                  <ScrollPane fitToWidth="true" prefHeight="532.0" prefWidth="213.0">
                     <content>
                        <VBox fx:id="leaderboardBox" prefHeight="502.0" prefWidth="213.0" />
                     </content>
                  </ScrollPane>
               </children>
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" top="10.0" />
               </HBox.margin>
            </VBox>

            <VBox alignment="TOP_CENTER" prefWidth="260.0" spacing="20.0" style="-fx-background-color: #F9EDE1;">
               <children>
                  <VBox alignment="TOP_CENTER" prefHeight="300.0" spacing="20.0" style="-fx-border-color: #DEB499; -fx-border-radius: 5; -fx-background-color: #FCE0D2;">
                     <children>
                        <Label text="Game List" textFill="#866b59">
                           <font>
                              <Font name="Dubai Medium" size="18.0" />
                           </font>
                        </Label>
                        <VBox fx:id="gameOptions" prefHeight="247.0" prefWidth="233.0" spacing="5.0">
                           <padding>
                              <Insets left="10.0" />
                           </padding>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </VBox>
                  <Button fx:id="gameSelectButton" mnemonicParsing="false" onAction="#onGameSelectButtonClick" prefHeight="55.0" prefWidth="215.0" styleClass="basic-button" text="Select An Opponent">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Button>
                  <Button fx:id="MatchMakeButton" layoutX="30.0" layoutY="340.0" mnemonicParsing="false" onAction="#onMatchMakeButtonClick" prefHeight="55.0" prefWidth="215.0" styleClass="basic-button" text="Find A Match">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Button>
                  <Label fx:id="errorField" textFill="#ff006e">
                     <font>
                        <Font name="Dubai Medium" size="12.0" />
                     </font></Label>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>

            <VBox alignment="TOP_CENTER" prefWidth="300.0" style="-fx-border-color: #DEB499; -fx-border-radius: 7; -fx-background-color: #FCE0D2;">
               <children>
                  <Label text="Game Details" textFill="#866b59">
                     <font>
                        <Font name="Dubai Medium" size="18.0" />
                     </font>
                  </Label>
                  <StackPane prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#ffc7ce" height="150.0" stroke="#ffc7ce" width="200.0" />
                        <Label text="Thumbnail" />
                     </children>
                  </StackPane>
                  <VBox alignment="CENTER" prefHeight="314.0" prefWidth="294.0" spacing="30.0">
                     <children>
                        <Label fx:id="gameTitleLabel" />
                        <Label fx:id="gameDescriptionLabel" wrapText="true" />
                        <Label fx:id="gameIdLabel" />
                        <Label fx:id="gameTagsLabel" />
                     </children>
                  </VBox>
               </children>
               <HBox.margin>
                  <Insets bottom="10.0" right="10.0" top="10.0" />
               </HBox.margin>
            </VBox>
         </children>
      </HBox>
   </center>
   <top>
      <HBox prefHeight="22.0" prefWidth="800.0" style="-fx-background-color: #F9EDE1;" BorderPane.alignment="CENTER">
         <children>
            <MenuBar maxHeight="35.0" minHeight="35.0" prefHeight="35.0" prefWidth="625.0" style="-fx-background-color: #F7C5AD;">
              <menus>
                <Menu mnemonicParsing="false" text="| View Player Stats |">
                     <items>
                        <MenuItem mnemonicParsing="false" text="View Player Stats" />
                     </items></Menu>
                <Menu mnemonicParsing="false" text="| Developper Info |">
                     <items>
                        <MenuItem mnemonicParsing="false" text="View Developer Credits" />
                        <MenuItem mnemonicParsing="false" text="View Application Information" />
                     </items>
                </Menu>
              </menus>
            </MenuBar>
            <ButtonBar maxHeight="35.0" minHeight="35.0" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #F7C5AD;">
              <buttons>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="🔍" />
                  <TextField fx:id="searchField" onAction="#handleSearch" prefHeight="26.0" style="-fx-background-color: #FCE0D2;" />
                <Button fx:id="logOutButton" maxHeight="28.0" minHeight="21.0" mnemonicParsing="false" onAction="#handleLogout" prefHeight="21.0" prefWidth="167.0" styleClass="basic-button" text="Log Out" />
              </buttons>
            </ButtonBar>
         </children></HBox>
   </top>
</BorderPane>
